generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      ="postgresql://hotel_user:hotel_pass@localhost:5432/hotel_db"
}

// ─── Users & Auth ────────────────────────────────────────────
model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  phone        String?
  passwordHash String
  role         Role     @default(RECEPTIONIST)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  guest        Guest?
  staff        Staff?
  notifications Notification[]
}

enum Role {
  SUPER_ADMIN
  ADMIN
  RECEPTIONIST
  HOUSEKEEPING
  MAINTENANCE
  GUEST
}

// ─── Guests ──────────────────────────────────────────────────
model Guest {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id])
  idProofType    String?
  idProofNumber  String?
  nationality    String?
  vipStatus      Boolean  @default(false)
  createdAt      DateTime @default(now())

  bookings       Booking[]
}

// ─── Room Categories ─────────────────────────────────────────
model RoomCategory {
  id            String   @id @default(uuid())
  name          String   @unique
  basePrice     Float
  maxOccupancy  Int
  amenities     Json     @default("[]")
  createdAt     DateTime @default(now())

  rooms         Room[]
}

// ─── Rooms ───────────────────────────────────────────────────
model Room {
  id             String     @id @default(uuid())
  roomNumber     String     @unique
  floor          Int
  categoryId     String
  category       RoomCategory @relation(fields: [categoryId], references: [id])
  status         RoomStatus @default(AVAILABLE)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  bookings           Booking[]
  sensors            Sensor[]
  housekeepingTasks  HousekeepingTask[]
  maintenanceRequests MaintenanceRequest[]
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  CLEANING
  MAINTENANCE
}

// ─── Bookings ────────────────────────────────────────────────
model Booking {
  id            String        @id @default(uuid())
  bookingRef    String        @unique @default(cuid())
  guestId       String
  guest         Guest         @relation(fields: [guestId], references: [id])
  roomId        String
  room          Room          @relation(fields: [roomId], references: [id])
  checkIn       DateTime
  checkOut      DateTime
  adults        Int           @default(1)
  children      Int           @default(0)
  status        BookingStatus @default(PENDING)
  parkingEnabled Boolean      @default(false)
  notes         String?
  paymentMethod String        @default("cash")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  extras          BookingExtra[]
  invoice         Invoice?
  parkingSessions ParkingSession[]
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
}

// ─── Booking Extras ──────────────────────────────────────────
model BookingExtra {
  id        String   @id @default(uuid())
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id])
  type      String
  amount    Float
  note      String?
  addedAt   DateTime @default(now())
}

// ─── Invoices ────────────────────────────────────────────────
model Invoice {
  id            String        @id @default(uuid())
  bookingId     String        @unique
  booking       Booking       @relation(fields: [bookingId], references: [id])
  roomCharge    Float
  parkingCharge Float         @default(0)
  extrasCharge  Float         @default(0)
  tax           Float
  discount      Float         @default(0)
  total         Float
  status        InvoiceStatus @default(UNPAID)
  paymentMethod String?
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

enum InvoiceStatus {
  UNPAID
  PAID
  PARTIALLY_PAID
  CANCELLED
}

// ─── Parking Sessions ────────────────────────────────────────
model ParkingSession {
  id               String   @id @default(uuid())
  bookingId        String
  booking          Booking  @relation(fields: [bookingId], references: [id])
  vehicleNumber    String
  bay              String?
  entryTime        DateTime @default(now())
  exitTime         DateTime?
  durationMinutes  Int?
  charge           Float?
  addedToInvoice   Boolean  @default(false)
  createdAt        DateTime @default(now())
}

// ─── Sensors ─────────────────────────────────────────────────
model Sensor {
  id        String     @id @default(uuid())
  sensorRef String     @unique
  type      SensorType
  location  String
  roomId    String?
  room      Room?      @relation(fields: [roomId], references: [id])
  status    SensorStatus @default(ACTIVE)
  lastPing  DateTime?
  createdAt DateTime   @default(now())

  events    IoTEvent[]
}

enum SensorType {
  DOOR
  GARAGE
  MOTION
  SMART_LOCK
}

enum SensorStatus {
  ACTIVE
  OFFLINE
  MAINTENANCE
}

// ─── IoT Events ──────────────────────────────────────────────
model IoTEvent {
  id        String    @id @default(uuid())
  sensorId  String
  sensor    Sensor    @relation(fields: [sensorId], references: [id])
  eventType String
  payload   Json      @default("{}")
  resolved  Boolean   @default(false)
  createdAt DateTime  @default(now())
}

// ─── Staff ───────────────────────────────────────────────────
model Staff {
  id         String   @id @default(uuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id])
  department String
  shift      String
  shiftStart String
  shiftEnd   String
  status     StaffStatus @default(ON_DUTY)
  joinDate   DateTime
  createdAt  DateTime @default(now())

  housekeepingTasks   HousekeepingTask[]
  maintenanceRequests MaintenanceRequest[]
}

enum StaffStatus {
  ON_DUTY
  OFF_DUTY
  ON_LEAVE
}

// ─── Housekeeping Tasks ──────────────────────────────────────
model HousekeepingTask {
  id          String     @id @default(uuid())
  roomId      String
  room        Room       @relation(fields: [roomId], references: [id])
  assignedTo  String
  staff       Staff      @relation(fields: [assignedTo], references: [id])
  type        String
  priority    Priority   @default(MEDIUM)
  status      TaskStatus @default(PENDING)
  note        String?
  completedAt DateTime?
  createdAt   DateTime   @default(now())
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
}

// ─── Maintenance Requests ────────────────────────────────────
model MaintenanceRequest {
  id          String   @id @default(uuid())
  roomId      String
  room        Room     @relation(fields: [roomId], references: [id])
  raisedBy    String
  staff       Staff    @relation(fields: [raisedBy], references: [id])
  issue       String
  status      TaskStatus @default(PENDING)
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())
}

// ─── Notifications ───────────────────────────────────────────
model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  body      String
  type      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}